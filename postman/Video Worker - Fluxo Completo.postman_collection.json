{
  "info": {
    "_postman_id": "609a0310-ef12-46b5-9ffc-6145612fc404",
    "name": "Video Worker - Fluxo Completo",
    "description": "Fluxo local faseado: infraestrutura, processamento com sucesso, idempotencia, falha e observabilidade.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "noauth"
  },
  "variable": [
    {
      "key": "workerBaseUrl",
      "value": "http://localhost:8083"
    },
    {
      "key": "kafkaRestBaseUrl",
      "value": "http://localhost:8084"
    },
    {
      "key": "minioBaseUrl",
      "value": "http://localhost:9000"
    },
    {
      "key": "minioAccessKey",
      "value": "fiapx"
    },
    {
      "key": "minioSecretKey",
      "value": "fiapx12345",
      "type": "secret"
    },
    {
      "key": "minioRegion",
      "value": "us-east-1"
    },
    {
      "key": "inputBucket",
      "value": "fiapx-videos-input"
    },
    {
      "key": "outputBucket",
      "value": "fiapx-videos-output"
    }
  ],
  "item": [
    {
      "name": "00 - Inicializacao",
      "description": "Gera os identificadores do fluxo de sucesso e valida os componentes HTTP.",
      "item": [
        {
          "name": "01 - Gerar IDs e validar liveness",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const guid = () => pm.variables.replaceIn('{{$guid}}');",
                  "const videoId = guid();",
                  "const customerId = guid();",
                  "pm.collectionVariables.set('videoId', videoId);",
                  "pm.collectionVariables.set('customerId', customerId);",
                  "pm.collectionVariables.set('requestEventId', guid());",
                  "pm.collectionVariables.set('inputObjectKey', `customers/${customerId}/videos/${videoId}/input/sample-video.mp4`);",
                  "pm.collectionVariables.set('successConsumerGroup', `postman-success-${guid()}`);",
                  "pm.collectionVariables.set('successConsumerInstance', `instance-${guid()}`);",
                  "pm.collectionVariables.unset('outputObjectKey');",
                  "pm.collectionVariables.unset('successPollAttempts');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Worker esta vivo', () => {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json().status).to.eql('UP');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{workerBaseUrl}}/actuator/health/liveness"
          }
        },
        {
          "name": "02 - Validar readiness",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('MongoDB, Kafka e MinIO estao prontos', () => {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json().status).to.eql('UP');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{workerBaseUrl}}/actuator/health/readiness"
          }
        },
        {
          "name": "03 - Validar Kafka REST Proxy",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Kafka REST Proxy esta disponivel', () => {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json()).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/vnd.kafka.v2+json"
              }
            ],
            "url": "{{kafkaRestBaseUrl}}/topics"
          }
        }
      ]
    },
    {
      "name": "01 - Sucesso",
      "description": "Envia um video real, aguarda o evento final, baixa o ZIP e repete a solicitacao.",
      "item": [
        {
          "name": "01 - Upload do video",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Video foi armazenado no bucket de entrada', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "awsv4",
              "awsv4": [
                {
                  "key": "accessKey",
                  "value": "{{minioAccessKey}}",
                  "type": "string"
                },
                {
                  "key": "secretKey",
                  "value": "{{minioSecretKey}}",
                  "type": "string"
                },
                {
                  "key": "region",
                  "value": "{{minioRegion}}",
                  "type": "string"
                },
                {
                  "key": "service",
                  "value": "s3",
                  "type": "string"
                }
              ]
            },
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "video/mp4"
              }
            ],
            "body": {
              "mode": "file",
              "file": {
                "src": "assets/sample-video.mp4"
              }
            },
            "url": "{{minioBaseUrl}}/{{inputBucket}}/{{inputObjectKey}}"
          }
        },
        {
          "name": "02 - Criar consumidor de resultado",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Consumidor temporario foi criado', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/vnd.kafka.v2+json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"{{successConsumerInstance}}\",\"format\":\"binary\",\"auto.offset.reset\":\"earliest\"}"
            },
            "url": "{{kafkaRestBaseUrl}}/consumers/{{successConsumerGroup}}"
          }
        },
        {
          "name": "03 - Assinar topicos de resultado",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Topicos de resultado foram assinados', () => pm.response.to.have.status(204));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/vnd.kafka.v2+json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"topics\":[\"video.processing.completed\",\"video.processing.failed\"]}"
            },
            "url": "{{kafkaRestBaseUrl}}/consumers/{{successConsumerGroup}}/instances/{{successConsumerInstance}}/subscription"
          }
        },
        {
          "name": "04 - Publicar VideoProcessingRequested",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const payload = {",
                  "  eventId: pm.collectionVariables.get('requestEventId'),",
                  "  eventType: 'VideoProcessingRequested',",
                  "  occurredAt: new Date().toISOString(),",
                  "  videoId: pm.collectionVariables.get('videoId'),",
                  "  customerId: pm.collectionVariables.get('customerId'),",
                  "  originalFilename: 'sample-video.mp4',",
                  "  inputObjectKey: pm.collectionVariables.get('inputObjectKey')",
                  "};",
                  "const encode = value => CryptoJS.enc.Base64.stringify(CryptoJS.enc.Utf8.parse(value));",
                  "pm.collectionVariables.set('requestKeyBase64', encode(payload.videoId));",
                  "pm.collectionVariables.set('requestValueBase64', encode(JSON.stringify(payload)));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Solicitacao foi publicada sem erro', () => {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json().offsets[0].error_code).to.eql(null);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/vnd.kafka.binary.v2+json"
              },
              {
                "key": "Accept",
                "value": "application/vnd.kafka.v2+json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"records\":[{\"key\":\"{{requestKeyBase64}}\",\"value\":\"{{requestValueBase64}}\"}]}"
            },
            "url": "{{kafkaRestBaseUrl}}/topics/video.processing.requested"
          }
        },
        {
          "name": "05 - Aguardar VideoProcessed",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const decode = value => CryptoJS.enc.Utf8.stringify(CryptoJS.enc.Base64.parse(value));",
                  "const records = pm.response.json();",
                  "const videoId = pm.collectionVariables.get('videoId');",
                  "const match = records.map(record => ({ record, value: JSON.parse(decode(record.value)) }))",
                  "  .find(entry => entry.value.videoId === videoId);",
                  "if (match) {",
                  "  pm.test('Evento de sucesso pertence ao video atual', () => {",
                  "    pm.expect(match.value.eventType).to.eql('VideoProcessed');",
                  "    pm.expect(decode(match.record.key)).to.eql(videoId);",
                  "  });",
                  "  pm.collectionVariables.set('outputObjectKey', match.value.outputObjectKey);",
                  "  pm.collectionVariables.unset('successPollAttempts');",
                  "} else {",
                  "  const attempts = Number(pm.collectionVariables.get('successPollAttempts') || 0) + 1;",
                  "  pm.collectionVariables.set('successPollAttempts', attempts);",
                  "  if (attempts < 30) {",
                  "    setTimeout(() => {}, 1000);",
                  "    pm.execution.setNextRequest(pm.info.requestName);",
                  "  } else {",
                  "    pm.test('Evento de sucesso chegou em ate 30 segundos', () => pm.expect.fail('VideoProcessed nao recebido'));",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/vnd.kafka.binary.v2+json"
              }
            ],
            "url": "{{kafkaRestBaseUrl}}/consumers/{{successConsumerGroup}}/instances/{{successConsumerInstance}}/records?timeout=1000"
          }
        },
        {
          "name": "06 - Download do ZIP",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('ZIP foi encontrado no bucket de saida', () => {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.headers.get('Content-Type')).to.include('zip');",
                  "  pm.expect(pm.response.responseSize).to.be.above(0);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "awsv4",
              "awsv4": [
                {
                  "key": "accessKey",
                  "value": "{{minioAccessKey}}",
                  "type": "string"
                },
                {
                  "key": "secretKey",
                  "value": "{{minioSecretKey}}",
                  "type": "string"
                },
                {
                  "key": "region",
                  "value": "{{minioRegion}}",
                  "type": "string"
                },
                {
                  "key": "service",
                  "value": "s3",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": "{{minioBaseUrl}}/{{outputBucket}}/{{outputObjectKey}}"
          }
        },
        {
          "name": "07 - Repetir evento idempotente",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Evento duplicado foi aceito pelo Kafka', () => {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json().offsets[0].error_code).to.eql(null);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/vnd.kafka.binary.v2+json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"records\":[{\"key\":\"{{requestKeyBase64}}\",\"value\":\"{{requestValueBase64}}\"}]}"
            },
            "url": "{{kafkaRestBaseUrl}}/topics/video.processing.requested"
          }
        },
        {
          "name": "08 - Remover consumidor",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Consumidor de sucesso foi removido', () => pm.response.to.have.status(204));"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/vnd.kafka.v2+json"
              }
            ],
            "url": "{{kafkaRestBaseUrl}}/consumers/{{successConsumerGroup}}/instances/{{successConsumerInstance}}"
          }
        }
      ]
    },
    {
      "name": "02 - Falha",
      "description": "Publica uma solicitacao cujo objeto nao existe e valida o evento sanitizado de falha.",
      "item": [
        {
          "name": "01 - Gerar IDs do fluxo de falha",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const guid = () => pm.variables.replaceIn('{{$guid}}');",
                  "const videoId = guid();",
                  "const customerId = guid();",
                  "pm.collectionVariables.set('failedVideoId', videoId);",
                  "pm.collectionVariables.set('failedCustomerId', customerId);",
                  "pm.collectionVariables.set('failedRequestEventId', guid());",
                  "pm.collectionVariables.set('missingInputObjectKey', `customers/${customerId}/videos/${videoId}/input/missing.mp4`);",
                  "pm.collectionVariables.set('failureConsumerGroup', `postman-failure-${guid()}`);",
                  "pm.collectionVariables.set('failureConsumerInstance', `instance-${guid()}`);",
                  "pm.collectionVariables.unset('failurePollAttempts');"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{workerBaseUrl}}/actuator/health/liveness"
          }
        },
        {
          "name": "02 - Criar consumidor de falha",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/vnd.kafka.v2+json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"{{failureConsumerInstance}}\",\"format\":\"binary\",\"auto.offset.reset\":\"earliest\"}"
            },
            "url": "{{kafkaRestBaseUrl}}/consumers/{{failureConsumerGroup}}"
          }
        },
        {
          "name": "03 - Assinar topico de falha",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/vnd.kafka.v2+json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"topics\":[\"video.processing.failed\"]}"
            },
            "url": "{{kafkaRestBaseUrl}}/consumers/{{failureConsumerGroup}}/instances/{{failureConsumerInstance}}/subscription"
          }
        },
        {
          "name": "04 - Publicar video inexistente",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const payload = {",
                  "  eventId: pm.collectionVariables.get('failedRequestEventId'),",
                  "  eventType: 'VideoProcessingRequested',",
                  "  occurredAt: new Date().toISOString(),",
                  "  videoId: pm.collectionVariables.get('failedVideoId'),",
                  "  customerId: pm.collectionVariables.get('failedCustomerId'),",
                  "  originalFilename: 'missing.mp4',",
                  "  inputObjectKey: pm.collectionVariables.get('missingInputObjectKey')",
                  "};",
                  "const encode = value => CryptoJS.enc.Base64.stringify(CryptoJS.enc.Utf8.parse(value));",
                  "pm.collectionVariables.set('failedKeyBase64', encode(payload.videoId));",
                  "pm.collectionVariables.set('failedValueBase64', encode(JSON.stringify(payload)));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/vnd.kafka.binary.v2+json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"records\":[{\"key\":\"{{failedKeyBase64}}\",\"value\":\"{{failedValueBase64}}\"}]}"
            },
            "url": "{{kafkaRestBaseUrl}}/topics/video.processing.requested"
          }
        },
        {
          "name": "05 - Aguardar VideoProcessingFailed",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const decode = value => CryptoJS.enc.Utf8.stringify(CryptoJS.enc.Base64.parse(value));",
                  "const records = pm.response.json();",
                  "const videoId = pm.collectionVariables.get('failedVideoId');",
                  "const match = records.map(record => ({ record, value: JSON.parse(decode(record.value)) }))",
                  "  .find(entry => entry.value.videoId === videoId);",
                  "if (match) {",
                  "  pm.test('Falha sanitizada pertence ao video atual', () => {",
                  "    pm.expect(match.value.eventType).to.eql('VideoProcessingFailed');",
                  "    pm.expect(match.value.failureReason).to.eql('Input video was not found');",
                  "    pm.expect(decode(match.record.key)).to.eql(videoId);",
                  "  });",
                  "  pm.collectionVariables.unset('failurePollAttempts');",
                  "} else {",
                  "  const attempts = Number(pm.collectionVariables.get('failurePollAttempts') || 0) + 1;",
                  "  pm.collectionVariables.set('failurePollAttempts', attempts);",
                  "  if (attempts < 30) {",
                  "    setTimeout(() => {}, 1000);",
                  "    pm.execution.setNextRequest(pm.info.requestName);",
                  "  } else {",
                  "    pm.test('Evento de falha chegou em ate 30 segundos', () => pm.expect.fail('VideoProcessingFailed nao recebido'));",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/vnd.kafka.binary.v2+json"
              }
            ],
            "url": "{{kafkaRestBaseUrl}}/consumers/{{failureConsumerGroup}}/instances/{{failureConsumerInstance}}/records?timeout=1000"
          }
        },
        {
          "name": "06 - Remover consumidor de falha",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/vnd.kafka.v2+json"
              }
            ],
            "url": "{{kafkaRestBaseUrl}}/consumers/{{failureConsumerGroup}}/instances/{{failureConsumerInstance}}"
          }
        }
      ]
    },
    {
      "name": "03 - Observabilidade",
      "item": [
        {
          "name": "01 - Readiness final",
          "request": {
            "method": "GET",
            "url": "{{workerBaseUrl}}/actuator/health/readiness"
          }
        },
        {
          "name": "02 - Metricas Prometheus",
          "request": {
            "method": "GET",
            "url": "{{workerBaseUrl}}/actuator/prometheus"
          }
        }
      ]
    }
  ]
}
